<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ContextMenuBuilder.WizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ContextMenuBuilder.Core.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:r="using:ContextMenuBuilder"
    mc:Ignorable="d">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:PageHeader Header="{x:Bind r:AppContext.AppLang.WizardTitle, Mode=OneWay}" />

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="4" Spacing="12">
                <TextBlock Text="{x:Bind r:AppContext.AppLang.WizardIntro, Mode=OneWay}" TextWrapping="Wrap" />
                <HyperlinkButton
                    Padding="0"
                    HorizontalAlignment="Left"
                    Content="{x:Bind r:AppContext.AppLang.WizardHelpLinkText, Mode=OneWay}"
                    NavigateUri="https://github.com/ikas-mc/ContextMenuBuilder/wiki/Help" />

                <StackPanel Spacing="8">


                    <Border
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="6">
                        <StackPanel Spacing="8">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{x:Bind r:AppContext.AppLang.WizardStep2Title, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.8"
                                Text="{x:Bind r:AppContext.AppLang.WizardStep2Description, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Opacity="0.8"
                                Text="{x:Bind r:AppContext.AppLang.WizardStep2Hint, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <Button
                                Width="220"
                                Click="OnOpenWinAppCliReleasesClicked"
                                Content="{x:Bind r:AppContext.AppLang.WizardStep2Button, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="6">
                        <StackPanel Spacing="8">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{x:Bind r:AppContext.AppLang.WizardStep1Title, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.8"
                                Text="{x:Bind r:AppContext.AppLang.WizardStep1Description, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <Button
                                Width="200"
                                Click="OnNavigateToSettingsClicked"
                                Content="{x:Bind r:AppContext.AppLang.WizardStep1Button, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="6">
                        <StackPanel Spacing="8">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{x:Bind r:AppContext.AppLang.WizardStep3Title, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.8"
                                Text="{x:Bind r:AppContext.AppLang.WizardStep3Description, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <Button
                                Width="200"
                                Click="OnNavigateToCertificatesClicked"
                                Content="{x:Bind r:AppContext.AppLang.WizardStep3Button, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="6">
                        <StackPanel Spacing="8">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{x:Bind r:AppContext.AppLang.WizardStep4Title, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.8"
                                Text="{x:Bind r:AppContext.AppLang.WizardStep4Description, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <Button
                                Width="200"
                                Click="OnNavigateToTemplateClicked"
                                Content="{x:Bind r:AppContext.AppLang.WizardStep4Button, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="6">
                        <StackPanel Spacing="8">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{x:Bind r:AppContext.AppLang.WizardStep5Title, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.8"
                                Text="{x:Bind r:AppContext.AppLang.WizardStep5Description, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <Button
                                Width="200"
                                Click="OnNavigateToMenusClicked"
                                Content="{x:Bind r:AppContext.AppLang.WizardStep5Button, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
